# ============================================================
# RAG 智能问答系统 - 环境变量配置
# 复制此文件为 .env 并填入你的配置值
# ============================================================

# -------------------- LLM 大模型配置 --------------------
# DashScope API Key（阿里云百炼平台）
# 申请地址：https://bailian.console.aliyun.com/
MODEL_API_KEY=sk-your-api-key-here
# 模型名称：qwen-plus / qwen-max / qwen-turbo 等
MODEL_MODEL_NAME=qwen-plus
# 请求超时（秒）
MODEL_TIMEOUT=30
# 最大重试次数
MODEL_MAX_RETRIES=3

# -------------------- 嵌入模型配置 --------------------
# 嵌入模型 API Key（通常和 MODEL_API_KEY 相同）
EMBEDDING_API_KEY=sk-your-api-key-here
# 嵌入模型名称
EMBEDDING_MODEL_NAME=text-embedding-v1
# 请求超时（秒）
EMBEDDING_TIMEOUT=30
# 最大重试次数
EMBEDDING_MAX_RETRIES=3

# -------------------- 服务配置 --------------------
# 服务监听地址
API_HOST=0.0.0.0
# 服务端口
API_PORT=8080

# -------------------- JWT 认证 --------------------
# JWT 签名密钥（留空则每次启动自动生成随机密钥）
# 生产环境请设置固定值，否则重启后已签发 token 将失效
JWT_SECRET_KEY=

# -------------------- Agent 配置 --------------------
# 是否启用问题重写（true/false）
AGENT_REWRITE_ENABLED=true

# -------------------- 检索配置 --------------------
# 向量检索 Top-K
VECTOR_SEARCH_TOP_K=20
# 关键词检索 Top-K
KEYWORD_SEARCH_TOP_K=20
# 重排序后返回的最终 Top-K
RERANK_TOP_K=5
# 默认检索返回数量
RETRIEVER_TOP_K=5

# -------------------- 存储路径 --------------------
# 向量数据库存储路径
RAG_DB_PATH=data/vector_db
# 对话数据库路径
CONVERSATION_DB_PATH=data/conversation.db

# -------------------- ChromaDB HNSW 索引参数 --------------------
# 距离度量：cosine / l2 / ip
HNSW_SPACE=cosine
# HNSW 图连接数
HNSW_M=16
# 构建时搜索宽度
HNSW_EF_CONSTRUCTION=200
# 查询时搜索宽度
HNSW_EF_SEARCH=50

# -------------------- 文档分块配置 --------------------
# 子块最小 token 数
SMALL_CHUNK_MIN_TOKENS=200
# 子块最大 token 数
SMALL_CHUNK_MAX_TOKENS=300
# 父块最小 token 数
BIG_CHUNK_MIN_TOKENS=1500
# 父块最大 token 数
BIG_CHUNK_MAX_TOKENS=2000
# 块重叠比例（0-1）
CHUNK_OVERLAP_RATIO=0.15
